{
  "name": "sqlite-document-db",
  "version": "2.0.0",
  "description": "Use SQLite as a JSON document database, with an API based on MongoDB's",
  "repository": {
    "type": "git",
    "url": "https://github.com/EtienneK/sqlite-document-db.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sqlite",
    "mongodb",
    "document-database",
    "json",
    "nosql",
    "embedded"
  ],
  "author": "Etienne Koekemoer",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "mongodb": "^7.5.0",
    "mongodb-memory-server": "^11.2.0",
    "oxlint": "^1.75.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
