{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["dist/", "backup/"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "es2024": true,
    "node": true
  },
  "rules": {
    "eqeqeq": ["error", "smart"],
    "no-var": "error",
    "prefer-const": "error",

    // "_id" is MongoDB's document identifier and is part of this library's
    // public API, so leading underscores are load-bearing here.
    "no-underscore-dangle": "off",
    // Cursors walk rows one at a time by design; the awaits cannot be batched.
    "no-await-in-loop": "off"
  },
  "overrides": [
    {
      "files": ["test/**/*.ts"],
      "rules": {
        "no-unused-expressions": "off",
        // Building expected documents with spread reads clearly in assertions.
        "no-map-spread": "off"
      }
    }
  ]
}
